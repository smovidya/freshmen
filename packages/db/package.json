{
  "name": "@vidyafreshmen/db",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config ../../apps/api/wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote --config ../../apps/api/wrangler.jsonc",
    "db:seed:local": "wrangler d1 execute DB --local --file=./seed.sql --config ../../apps/api/wrangler.jsonc",
    "db:seed:remote": "wrangler d1 execute DB --remote --file=./seed.sql --config ../../apps/api/wrangler.jsonc",
    "db:studio": "drizzle-kit studio"
  },
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./index.js"
    },
    "./schemas": {
      "import": "./schemas/schema.ts",
      "require": "./schemas/schema.js"
    }
  },
  "types": "index.d.ts",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250712.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv": "^17.2.0"
  }
}