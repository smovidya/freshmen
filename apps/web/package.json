{
	"name": "@vidyafreshmen/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"deploy": "wrangler deploy --minify",
		"dev:worker": "vite build --watch --mode development & wrangler dev",
		"cf-typegen": "wrangler types src/worker-configuration.d.ts",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"auth:migrate:local": "wrangler d1 migrations apply DB --local",
		"auth:migrate:remote": "wrangler d1 migrations apply DB --remote"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.25.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^26.1.1",
		"@types/qrcode": "^1.5.6",
		"@vidyafreshmen/typescript-config": "workspace:*",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"formsnap": "^2.0.1",
		"lucide-svelte": "^1.0.1",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.64.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.1.5",
		"vite-plugin-devtools-json": "^1.0.0",
		"wrangler": "4.25.1"
	},
	"dependencies": {
		"@fontsource-variable/noto-sans-thai": "^5.2.8",
		"@number-flow/svelte": "^0.4.2",
		"@vanillaes/csv": "^4.1.3",
		"@vidyafreshmen/auth": "workspace:*",
		"@vidyafreshmen/db": "workspace:*",
		"@vidyafreshmen/flags": "workspace:*",
		"@vidyafreshmen/server": "workspace:*",
		"better-auth": "^1.6.23",
		"drizzle-orm": "^0.45.2",
		"google-auth-library": "^10.1.0",
		"google-spreadsheet": "^4.1.5",
		"hono": "^4.8.4",
		"jose": "^6.0.12",
		"qr-scanner": "^1.4.2",
		"qrcode": "^1.5.4",
		"svelte-dnd-action": "^0.9.74",
		"zod": "^4.4.3"
	}
}
