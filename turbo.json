{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".svelte-kit/**",
        ".vercel/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "dependsOn": [
        "^dev"
      ],
      "cache": false,
      "persistent": true,
      "env": [
        "PUBLIC_BETTER_AUTH_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "PUBLIC_API_URL",
        "BETTER_AUTH_SECRET"
      ]
    },
    "dev:worker": {
      "cache": false,
      "persistent": true
    },
    "db:migrate:local": {
      "cache": false
    },
    "db:migrate:remote": {
      "cache": false
    },
    "db:seed:local": {
      "dependsOn": [
        "db:migrate:local"
      ],
      "cache": false
    },
    "db:seed:remote": {
      "dependsOn": [
        "db:migrate:remote"
      ],
      "cache": false
    },
    "deploy": {
      "cache": false,
      "env": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN"
      ],
      "outputLogs": "new-only"
    }
  }
}